								<Column width="4.5rem" visible="{viewModel>/mes12Visible}">
									<m:Label text="12"/>
									<template>
										<m:Input value="{viewModel>Mes12}" enabled="false"/>
									</template>
								</Column>
								<Column width="4.5rem">
									<m:Label text="Total general"/>
									<template>
										<m:Input value="{path: 'viewModel>Total', type:'sap.ui.model.type.Float', formatOptions: { maxFractionDigits: 2 }}" editable="false"/>
									</template>
								</Column>
								<Column width="4.5rem">
									<m:Label text="Promedio"/>
									<template>
										<m:Input value="{path: 'viewModel>Promedio', type:'sap.ui.model.type.Float', formatOptions: { maxFractionDigits: 2 }}" editable="false"/>
									</template>
								</Column>
							</columns>
						</Table>
					</m:IconTabFilter>
				</m:items>
			</m:IconTabBar>
		</m:content>
		<m:footer>
			<m:Toolbar width="100%" id="toolbar2">
				<m:content>
					<m:ToolbarSpacer/>
					<m:Button text="Guardar" type="Accept" press="onSaveData" id="buttonSave"/>
				</m:content>
			</m:Toolbar>
		</m:footer>
	</m:Page>
	</mvc:View>